{
  "schemaVersion": 1,
  "id": "lavaboats",
  "version": "${version}",
  "name": "Lava Boats",
  "description": "Adds Crimson and Warped boats (with chest variants) that ride on lava like water, never burn, and protect their passengers from fire. Install on the server for the protection features; install on clients for full lava-riding capability.",
  "authors": ["Kishku7"],
  "contact": {
    "homepage": "https://modrinth.com/mod/lava-boats",
    "sources": "https://github.com/Kishku7/lava-boats",
    "issues": "https://github.com/Kishku7/lava-boats/issues"
  },
  "license": "ARR",
  "icon": "assets/lavaboats/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": ["com.kishku7.lavaboats.LavaBoats"],
    "client": ["com.kishku7.lavaboats.client.LavaBoatsClient"]
  },
  "mixins": [
    "lavaboats.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.0",
    "minecraft": "~26.1",
    "fabric-api": ">=0.145.0"
  }
}
